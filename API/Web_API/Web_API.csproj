    <EmbeddedResource Remove="fonts\**" />
    <None Remove="fonts\**" />

    <Compile Remove="Scripts\**" />
    <Content Remove="Scripts\**" />
    <EmbeddedResource Remove="Scripts\**" />
    <None Remove="Scripts\**" />

    <Compile Remove="Global.asax.cs" />
