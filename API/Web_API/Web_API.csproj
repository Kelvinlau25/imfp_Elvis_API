    <None Remove="Global.asax" />
    <None Remove="Web.config" />
    <None Remove="Web.Debug.config" />
    <None Remove="Web.Release.config" />
    <None Remove="Web1.config" />
    <None Remove="Web1.Debug.config" />
    <None Remove="Web1.Release.config" />
    <None Remove="packages.config" />
    <None Remove="Web_API.csproj.bak" />
    <None Remove="Web_API.csproj.bak2" />
  </ItemGroup>

</Project>
